<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/styles/main-interface.css" />
    <link rel="stylesheet" href="/styles/table.css" />
    <link rel="stylesheet" href="/styles/quote.css" />
  </head>
  <body>
    <!--TOP BAR-->
    <div class="top-bar">
      <h1>Quote System</h1>
    </div>

    <!--MAIN SECTION-->
    <div class="main-section">
      <!--QUOTE LIST-->
      <div class="quote-list">
        <button id="createQuote" type="button">Create Quote</button>
        <br />
        <input
          type="text"
          id="search"
          name="search"
          placeholder="Search Quotes"
        />
        <button id="searchQuotes" type="button">Search</button>

        <table>
          <colgroup>
            <col style="width: 10%" />
            <col style="width: 40%" />
            <col style="width: 10%" />
            <col style="width: 10%" />
            <col style="width: 10%" />
            <col style="width: 10%" />
          </colgroup>

          <thead>
            <tr>
              <th>Quote Id</th>
              <th>Description</th>
              <th>Customer</th>
              <!-- <th>Price</th> -->
              <!-- <th>Associate</th> -->
              <th>Status</th>
              <th>View</th>
            </tr>

            <% quotes.forEach(function(quote){ %>
            <tr>
              <td><%= quote.id %></td>
              <td><%= quote.description %></td>
              <td><%= quote.customer.name %></td>
              <!-- <td>$<%= quote.price %></td> -->
              <!-- <td><%= quote.associate %></td> -->
              <td><%= quote.status %></td>
              <td><a href="?id=<%= quote.id %>">View</a></td>
            </tr>
            <% }); %>
          </thead>
        </table>
      </div>

      <!--DIVIDER-->
      <div class="vl"></div>

      <!--QUOTE VIEW-->
      <div class="quote-view">
        <div class="quote-id">
          <h2>
            Quote #
            <%= selectedQuote.id %>
          </h2>
        </div>

        <div class="quote-details">
          <div class="customer-details">
            <hr />
            <ul>
              <li><%= selectedQuote.customer.name %></li>
              <li>Customer Phone #</li>
              <li><%= selectedQuote.customer.email %></li>
              <li><%= selectedQuote.customer.address %></li>
            </ul>
          </div>

          <div class="line-items">
            <table>
              <colgroup>
                <col style="width: 10%" />
                <col style="width: 70%" />
                <col style="width: 20%" />
              </colgroup>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Line Item</th>
                  <th>Price</th>
                </tr>
              </thead>

              <% for (const lineitem of selectedQuote.lineitems) { %>
              <tr>
                <td><%= lineitem.id%></td>
                <td><%= lineitem.description %></td>
                <td><%= lineitem.price %></td>
              </tr>
              <% } %>
            </table>
          </div>

          <div class="notes">
            <div id="notes">
              <h2>Notes</h2>
            </div>
          </div>
          <div class="price">
            <div id="price">
              <h2>
                <span>Total: </span>
                <span>
                  <%= selectedQuote.lineitems.reduce((acc, item) => acc +
                  item.price, 0) %>
                </span>
              </h2>
              <hr />
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
